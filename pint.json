{
    "preset": "laravel",
    "rules": {
        "array_syntax": {
            "syntax": "short"
        },
        "concat_space": {
            "spacing": "one"
        },
        "no_unused_imports": true,
        "ordered_imports": true,
        "not_operator_with_successor_space": true,
        "binary_operator_spaces": {
            "operators": {
                "=>": "align_single_space",
                "=": "align_single_space"
            }
        },
        "method_argument_space": {
            "on_multiline": "ensure_fully_multiline"
        }
    },
    "exclude": [
        "bootstrap/cache",
        "storage",
        "vendor"
    ]
}
